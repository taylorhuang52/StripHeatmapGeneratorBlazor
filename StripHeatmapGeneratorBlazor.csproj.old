<Project Sdk="Microsoft.NET.Sdk.BlazorWebAssembly">
 
  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <ServiceWorkerAssetsManifest>service-worker-assets.js</ServiceWorkerAssetsManifest>
    <RootNamespace>StripHeatmapGeneratorBlazor</RootNamespace>
    <!-- SkiaSharp 在 Blazor WASM 需要允許 unsafe + 保留 native -->
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <WasmNativeStrip>false</WasmNativeStrip>
  </PropertyGroup>
 
  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly" Version="9.0.0" />
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly.DevServer" Version="9.0.0" PrivateAssets="all" />
    <PackageReference Include="SkiaSharp" Version="2.88.8" />
    <PackageReference Include="SkiaSharp.Views.Blazor" Version="2.88.8" />
    <!-- 必須加這個，才會帶入 libSkiaSharp.a 給 WASM native linker -->
    <PackageReference Include="SkiaSharp.NativeAssets.WebAssembly" Version="2.88.8" />
  </ItemGroup>
 
  <ItemGroup>
    <ServiceWorker Include="wwwroot\service-worker.js" ContentRoot="wwwroot" />
  </ItemGroup>
 
</Project>
 